:root{font-family:Inter,Segoe UI,Arial,sans-serif;color:#001c47;background:#eef4fb}*{box-sizing:border-box}body{margin:0}.app{display:flex;min-height:100vh}.sidebar{width:265px;background:#07172d;color:white;padding:20px 16px;position:fixed;inset:0 auto 0 0}.brand{display:flex;gap:12px;align-items:center;margin-bottom:28px}.brand span{display:block;font-size:13px;font-weight:400}.logo{background:#3367ee;border-radius:14px;padding:16px 12px;font-weight:900}label{display:block;margin:10px 0 8px;color:#dce8ff}select,input{width:100%;border:1px solid #bfd4f5;border-radius:12px;padding:14px 16px;font-size:15px;background:white;color:#001c47}.sidebar select{margin-bottom:24px}nav button{display:flex;width:100%;align-items:center;gap:12px;background:transparent;color:white;border:0;padding:14px;border-radius:12px;font-weight:800;font-size:15px;cursor:pointer}nav button.active,nav button:hover{background:#3869ef}main{margin-left:265px;padding:28px 34px;width:calc(100% - 265px)}header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:28px}h1{font-size:34px;line-height:1.15;margin:0 0 12px;font-weight:900}h2{font-size:25px;margin:0 0 18px}h3{margin:20px 0 12px}.ok{background:#cbfbd7;color:#006b24;padding:16px 24px;border-radius:22px;font-weight:900;display:flex;gap:10px}.card{background:white;border-radius:22px;padding:26px;margin:18px 0;box-shadow:0 14px 32px #001c4712}.cardHead{display:flex;justify-content:space-between;align-items:center}.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}.stats div{background:white;border-radius:18px;padding:20px;box-shadow:0 10px 24px #001c4710}.stats b{display:block;font-size:35px;margin-top:6px}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}.grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:18px}.grid5{display:grid;grid-template-columns:1.2fr 1fr 1fr 1fr 1fr;gap:12px;margin-bottom:12px}.inline{display:flex;gap:12px;align-items:center}.inline input{min-width:0}.box{background:#f4f8ff;border:1px solid #cfe0fb;border-radius:16px;padding:14px;margin-bottom:18px}.toolbar{display:flex;gap:10px;flex-wrap:wrap;margin:16px 0}button{border:0;border-radius:12px;background:#3869ef;color:white;padding:13px 18px;font-weight:900;font-size:15px;display:inline-flex;align-items:center;gap:8px;cursor:pointer}button:disabled{opacity:.45;cursor:not-allowed}.danger{background:#ffe2e2;color:#ce1c1c}.success{background:#d6f9df;color:#006b24}.soft{background:#a9befa;color:white}.small{padding:8px 10px}table{width:100%;border-collapse:separate;border-spacing:0;border:1px solid #cfe0fb;border-radius:14px;overflow:hidden;margin-top:14px}th{background:#eef4fb;text-align:left;padding:14px;font-size:14px}td{border-top:1px solid #d9e6f7;padding:12px;vertical-align:top}tr.rowActive{background:#edf4ff}.empty{text-align:center;color:#60708a;padding:30px}.badge{background:#edf4ff;padding:12px 18px;border-radius:18px;font-weight:900}.total{text-align:right;margin-top:20px}.subcard{background:#f7faff;border:1px dashed #8fb2ef;border-radius:16px;padding:18px;margin-top:18px}.est{background:white;border:1px solid #d9e6f7;border-radius:14px;padding:14px;margin-top:12px}.est span{display:block;color:#60708a;margin-top:4px}.areas{display:flex;gap:8px;flex-wrap:wrap;margin:10px 0}.areas em{background:#eaf1ff;border-radius:999px;padding:7px 10px;font-style:normal;font-weight:700}@media(max-width:850px){.sidebar{position:static;width:100%}.app{display:block}main{margin:0;width:100%;padding:18px}.grid2,.grid3,.grid5,.stats{grid-template-columns:1fr}.inline{flex-direction:column;align-items:stretch}header{flex-direction:column;gap:12px}}@media print{.sidebar,.toolbar,button,.ok{display:none!important}main{margin:0;width:100%;padding:0}.card{box-shadow:none;border:0}body{background:white}}
